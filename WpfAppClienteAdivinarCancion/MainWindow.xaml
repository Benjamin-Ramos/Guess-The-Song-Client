<Window x:Class="WpfAppClienteAdivinarCancion.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:WpfAppClienteAdivinarCancion"
        Icon="pack://application:,,,/WpfAppClienteAdivinarCancion;component/Assets/favicon.ico"
        Title="Adivina la Canción - Desktop Edition" Height="750" Width="1100"
        Background="#F8F9FA" WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <local:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVis" />

        <Style x:Key="ButtonStyleCancion" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Padding" Value="20,15"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="#E0E0E0" 
                                BorderThickness="1.5" 
                                CornerRadius="15"
                                Padding="{TemplateBinding Padding}">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" Color="Black" Opacity="0.1" ShadowDepth="2"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center">
                                <ContentPresenter.ContentTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" 
                                                   TextWrapping="Wrap" 
                                                   TextAlignment="Center"
                                                   MaxHeight="60"
                                                   VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </ContentPresenter.ContentTemplate>
                            </ContentPresenter>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F1F3F5"/>
                    <Setter Property="BorderBrush" Value="#0078D4"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#E9ECEF"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.4"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Border Visibility="{Binding MostrarPodio, Converter={StaticResource BoolToVis}}" 
                Background="#EE000000" 
                Grid.ColumnSpan="3" 
                Panel.ZIndex="1000">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="🏆 PODIO FINAL 🏆" FontSize="48" Foreground="Gold" FontWeight="Bold" Margin="0,0,0,30"/>
                <ItemsControl ItemsSource="{Binding ListaPodio}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#33FFFFFF" CornerRadius="10" Margin="5" Padding="15">
                                <DockPanel Width="400">
                                    <TextBlock Text="{Binding Nombre}" FontSize="24" Foreground="White" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding PuntosTotales, StringFormat='{}{0} PTS'}" 
                                               DockPanel.Dock="Right" TextAlignment="Right"
                                               FontSize="24" Foreground="LightGreen" FontWeight="Black"/>
                                </DockPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <Button Content="CERRAR Y VOLVER" 
                        Command="{Binding CerrarPodioCommand}" 
                        Margin="0,30,0,0" Padding="20,10" FontSize="18"/>
            </StackPanel>
        </Border>

        <Border Visibility="{Binding EstaConectado, Converter={StaticResource InverseBoolToVis}}"
                Width="400" Height="550" Background="White" CornerRadius="20" VerticalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect BlurRadius="30" Color="Black" Opacity="0.1" ShadowDepth="0"/>
            </Border.Effect>
            <StackPanel Margin="40">
                <TextBlock Text="🎵" FontSize="50" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                <TextBlock Text="Adivina la Cancion" FontSize="28" FontWeight="Black" HorizontalAlignment="Center" Foreground="#333"/>
                <TextBlock Text="Multijugador" FontSize="14" HorizontalAlignment="Center" Foreground="#888" Margin="0,0,0,30"/>
                <TextBlock Text="URL del Servidor" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="TxtUrl" Text="" Padding="10" Margin="0,0,0,15"/>
                <TextBlock Text="Tu Nick" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="TxtNick" Text="" Padding="10" Margin="0,0,0,15"/>
                <TextBlock Text="Código de Sala (Si no existe se creara)" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="TxtSala" Text="" Padding="10" Margin="0,0,0,30"/>
                <Button Content="CONECTAR" Click="BtnConectar_Click" Height="50" Background="#0078D4" Foreground="White" FontWeight="Bold" FontSize="16">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="10"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Border>

        <Grid Visibility="{Binding EstaConectado, Converter={StaticResource BoolToVis}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="350"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="25">
                <Grid Visibility="{Binding EnPartida, Converter={StaticResource InverseBoolToVis}}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="Esperando a que empiece la partida..." FontSize="24" FontWeight="Light" Foreground="#666" Margin="0,0,0,30"/>
                        <Border Background="#FFF9DB" CornerRadius="15" Padding="30" Visibility="{Binding EsHost, Converter={StaticResource BoolToVis}}" Width="500">
                            <StackPanel>
                                <TextBlock Text="PANEL DEL HOST" FontWeight="Black" FontSize="14" Foreground="#856404" Margin="0,0,0,20"/>
                                <TextBlock Text="Artista para esta partida:" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                <TextBox x:Name="TxtArtistaBusqueda" Text="Bad Bunny" FontSize="18" Padding="10" Margin="0,0,0,20"/>
                                <Button Content="🚀 EMPEZAR PARTIDA" Click="BtnEmpezar_Click" Height="60" FontSize="20" FontWeight="Black" Background="#FCC419"/>
                                <Button Content="Limpiar Puntuaciones" 
                                        Click="BtnReiniciarPuntos_Click"
                                        Margin="0,15,0,0"
                                        Height="35" 
                                        Background="Transparent" 
                                        BorderBrush="#856404" 
                                        BorderThickness="1"
                                        Foreground="#856404" 
                                        FontSize="13" 
                                        Cursor="Hand">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#FFF3BF"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <Grid Visibility="{Binding EnPartida, Converter={StaticResource BoolToVis}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#0078D4" CornerRadius="15" Padding="15" Margin="0,0,0,10">
                        <Viewbox MaxHeight="55">
                            <TextBlock Text="{Binding MensajeJuego}" FontWeight="Bold" Foreground="White"/>
                        </Viewbox>
                    </Border>

                    <Grid Grid.Row="1" Margin="0,5,0,20">
                        <Rectangle Height="8" Fill="#22000000" RadiusX="4" RadiusY="4"/>
                        <Rectangle Height="8" Fill="Gold" RadiusX="4" RadiusY="4" RenderTransformOrigin="0.5,0.5">
                            <Rectangle.RenderTransform>
                                <ScaleTransform ScaleX="1"/>
                            </Rectangle.RenderTransform>
                            <Rectangle.Style>
                                <Style TargetType="Rectangle">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding PuedeResponder}" Value="True">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard x:Name="TimerStoryboard">
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                                         From="1.0" To="0.0" Duration="0:0:25" />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                            <DataTrigger.ExitActions>
                                                <StopStoryboard BeginStoryboardName="TimerStoryboard"/>
                                            </DataTrigger.ExitActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Rectangle.Style>
                        </Rectangle>
                    </Grid>

                    <Viewbox Grid.Row="2" Stretch="Uniform" VerticalAlignment="Center">
                        <StackPanel Width="700">
                            <Border MaxWidth="450" MaxHeight="320" MinHeight="180" 
                                    CornerRadius="20" Background="Black" ClipToBounds="True" HorizontalAlignment="Center">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="30" Color="Black" Opacity="0.3" ShadowDepth="5"/>
                                </Border.Effect>
                                <Grid>
                                    <Image Source="{Binding PortadaAlbumActual}" Stretch="UniformToFill"/>
                                    <Image Source="{Binding FotoArtista}" Stretch="UniformToFill" HorizontalAlignment="Center">
                                        <Image.Style>
                                            <Style TargetType="Image">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding MostrarPortadaReal}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Image.Style>
                                    </Image>
                                </Grid>
                            </Border>

                            <TextBlock Text="¿CUÁL ES EL TÍTULO?" HorizontalAlignment="Center" 
                                       FontWeight="Black" Foreground="#ADB5BD" Margin="0,25,0,10" FontSize="14"/>

                            <ItemsControl ItemsSource="{Binding OpcionesBotones}" Margin="10,0">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="2"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Content="{Binding}"
                                                Style="{StaticResource ButtonStyleCancion}"
                                                Margin="5"
                                                Click="BtnRespuesta_Click"
                                                IsEnabled="{Binding DataContext.PuedeResponder,
                                                RelativeSource={RelativeSource AncestorType=ItemsControl}}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Viewbox>
                </Grid>
            </Grid>

            <Grid Grid.Column="1" Background="White">
                <Grid.RowDefinitions>
                    <RowDefinition Height="2*"/>
                    <RowDefinition Height="3*"/>
                </Grid.RowDefinitions>
                <Border BorderBrush="#EEE" BorderThickness="1,0,0,0"/>
                <GroupBox Header="🏆 CLASIFICACIÓN" Margin="15" FontWeight="Black" BorderThickness="0">
                    <ListBox ItemsSource="{Binding ListaJugadores}" BorderThickness="0" Background="Transparent" Margin="0,10">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#F8F9FA" CornerRadius="10" Padding="12" Margin="0,0,0,8">
                                    <DockPanel>
                                        <TextBlock Text="👑" Visibility="{Binding EsHost, Converter={StaticResource BoolToVis}}" Margin="0,0,10,0"/>
                                        <TextBlock Text="{Binding Nombre}" FontWeight="Bold" FontSize="14" Margin="0,0,20,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding PuntosTotales, StringFormat='{}{0} PTS'}" Foreground="#28a745" FontSize="16" VerticalAlignment="Center" DockPanel.Dock="Right" TextAlignment="Right"/>
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </GroupBox>
                <Grid Grid.Row="1" Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="💬 CHAT DE LA SALA" FontWeight="Black" Margin="0,0,0,10"/>
                    <Border VerticalAlignment="Bottom" Margin="0,15,0,0" 
                            Background="#F8F9FA" CornerRadius="10" Padding="10">
                        <StackPanel>
                            <DockPanel LastChildFill="True">
                                <TextBlock Text="🔈" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding VolumenActual, StringFormat={}{0:0}%}" 
                                           DockPanel.Dock="Right" 
                                           Width="30" 
                                           FontSize="11" 
                                           Foreground="#666" 
                                           VerticalAlignment="Center" 
                                           TextAlignment="Right"/>
                                <Slider Minimum="0" 
                                        Maximum="100" 
                                        Value="{Binding VolumenActual, Mode=TwoWay}" 
                                        VerticalAlignment="Center"/>
                            </DockPanel>
                        </StackPanel>
                    </Border>
                    <ListBox Grid.Row="1" ItemsSource="{Binding MensajesChat}" Background="#F1F3F5" BorderThickness="0">
                        <ListBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </ListBox.Resources>
                    </ListBox>
                    <DockPanel Grid.Row="2" Margin="0,10,0,0">
                        <Button Content="➤" Click="BtnEnviarChat_Click" DockPanel.Dock="Right" Width="40" Background="#0078D4" Foreground="White" FontWeight="Bold" Margin="5,0,0,0"/>
                        <TextBox x:Name="TxtMensajeChat" Padding="8" KeyDown="TxtMensajeChat_KeyDown"/>
                    </DockPanel>
                </Grid>
            </Grid>
        </Grid>
        <Border Visibility="{Binding MostrandoConteo, Converter={StaticResource BoolToVis}}" 
                Background="#CC000000" 
                Grid.ColumnSpan="3" 
                Panel.ZIndex="1500">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Viewbox MaxHeight="400">
                    <TextBlock Text="{Binding SegundosConteo}" 
                               Foreground="White" 
                               FontWeight="Black"
                               TextAlignment="Center">
                        <TextBlock.Effect>
                            <DropShadowEffect BlurRadius="30" Color="#0078D4" ShadowDepth="0"/>
                        </TextBlock.Effect>
                    </TextBlock>
                </Viewbox>
                <TextBlock Text="¡Suerte!" Foreground="#ADB5BD" FontSize="24" 
                           FontWeight="Bold" HorizontalAlignment="Center" Margin="0,20,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>